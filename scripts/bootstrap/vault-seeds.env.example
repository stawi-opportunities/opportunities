# vault-seeds.env.example — copy to vault-seeds.env, fill values, then run seed-vault.sh
# This file is safe to commit. vault-seeds.env is git-ignored.

# Iceberg SQL catalog DSN. Must be reachable from the k8s cluster pooler.
# Format: postgres://user:pass@pooler-rw.datastore.svc:5432/stawi_jobs?sslmode=require
ICEBERG_CATALOG_URI=postgres://stawi_jobs:CHANGEME@pooler-rw.datastore.svc:5432/stawi_jobs?sslmode=require

# R2 event-log bucket credentials (separate token scoped to stawi-jobs-log bucket).
# Account ID is the 32-char hex from the Cloudflare dashboard.
R2_LOG_ACCOUNT_ID=0000000000000000000000000000000000000000
R2_LOG_ACCESS_KEY_ID=CHANGEME_ACCESS_KEY
R2_LOG_SECRET_ACCESS_KEY=CHANGEME_SECRET_KEY
# Endpoint format: https://<account_id>.r2.cloudflarestorage.com
R2_LOG_ENDPOINT=https://0000000000000000000000000000000000000000.r2.cloudflarestorage.com
