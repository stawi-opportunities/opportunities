# vault-seeds.env.example — copy to vault-seeds.env, fill values, then run seed-vault.sh
# This file is safe to commit. vault-seeds.env is git-ignored.

# Iceberg SQL catalog DSN. Must be reachable from the k8s cluster pooler.
# Format: postgres://user:pass@pooler-rw.datastore.svc:5432/stawi_jobs?sslmode=require
ICEBERG_CATALOG_URI=postgres://stawi_jobs:CHANGEME@pooler-rw.datastore.svc:5432/stawi_jobs?sslmode=require

# Cloudflare R2 — single account token authorised on all three product
# buckets (cluster-chronicle, product-opportunities-content,
# product-opportunities-archive). Bucket names are NOT secrets — they
# live as plain values in HelmRelease env blocks.
#
# Provision the token in the Cloudflare dashboard with R2 Read+Write on
# all three buckets, then paste its key ID + secret here.
R2_ACCOUNT_ID=0000000000000000000000000000000000000000
R2_ACCESS_KEY_ID=CHANGEME_ACCESS_KEY
R2_SECRET_ACCESS_KEY=CHANGEME_SECRET_KEY
# Endpoint format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://0000000000000000000000000000000000000000.r2.cloudflarestorage.com

# Optional: Cloudflare Pages deploy hook URL for the public Hugo site
# (job-repo CDN). Used by api/crawler to trigger a Pages rebuild after
# publish. Leave blank to disable.
R2_DEPLOY_HOOK_URL=
