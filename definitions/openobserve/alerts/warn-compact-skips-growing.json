{
  "name": "warn-compact-skips-growing",
  "org_id": "stawi-jobs",
  "stream_type": "metrics",
  "stream_name": "default",
  "is_real_time": false,
  "query_condition": {
    "conditions": null,
    "sql": null,
    "promql": "increase(iceberg_compact_partitions_skipped_total[1h]) > 500",
    "promql_condition": {
      "operator": ">",
      "value": 0
    },
    "type": "promql"
  },
  "trigger_condition": {
    "period": 10,
    "operator": ">=",
    "threshold": 1,
    "silence": 60,
    "frequency": 10,
    "cron": ""
  },
  "destinations": ["slack-platform-alerts"],
  "context_attributes": {
    "severity": "warning",
    "team": "platform",
    "runbook": "https://docs.stawi.jobs/ops/runbooks/compact-skips"
  },
  "description": "More than 500 partitions were skipped in the last compaction hour, suggesting the compactor is not keeping up with write volume. Review reason labels (already_large, single_file, other).",
  "enabled": true
}
