{
  "version": 1,
  "acquisition": "api",
  "kind": { "mode": "fixed", "fixed": "job" },
  "list": {
    "mode": "api",
    "endpoint": "https://jobicy.com/api/v2/remote-jobs",
    "method": "GET",
    "headers": { "Accept": "application/json" },
    "params": { "count": "50" },
    "items_path": "$.jobs",
    "pagination": { "mode": "none" }
  },
  "detail": {
    "record_source": "record",
    "title": { "from": ["record"], "json_path": "$.jobTitle", "required": true },
    "description": { "from": ["record"], "json_path": "$.jobExcerpt", "required": true },
    "issuing_entity": { "from": ["record"], "json_path": "$.companyName", "required": true },
    "apply_url": {
      "from": ["record"],
      "json_path": "$.url",
      "required": true,
      "transform": ["absolute_url"]
    },
    "location_text": { "from": ["record"], "json_path": "$.jobGeo" },
    "currency": { "from": ["record"], "json_path": "$.salaryCurrency" },
    "remote": { "from": ["const"], "const": "true" },
    "attributes": {
      "employment_type": { "from": ["record"], "json_path": "$.jobType" },
      "remote_type": { "from": ["const"], "const": "remote" },
      "external_id": { "from": ["record"], "json_path": "$.id" }
    }
  }
}
