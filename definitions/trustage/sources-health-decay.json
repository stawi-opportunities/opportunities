{
  "version": "1.0",
  "name": "stawi-jobs.sources.health-decay",
  "description": "Every hour at :15 — nudges every active source's health_score toward 1.0 by a small step (0.05). Allows sources that were degraded by transient failures to self-recover without manual intervention.",
  "schedule": {
    "cron": "15 * * * *",
    "active": true
  },
  "input": {},
  "config": {},
  "timeout": "10m",
  "on_error": {
    "action": "abort"
  },
  "steps": [
    {
      "id": "health_decay",
      "type": "call",
      "name": "Decay health scores toward 1.0",
      "timeout": "5m",
      "retry": {
        "max_attempts": 3,
        "backoff_strategy": "exponential",
        "initial_backoff": "15s"
      },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-crawler.stawi-jobs.svc/admin/sources/health-decay",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": {}
        }
      }
    }
  ]
}
