          "body": { "collection": "candidates_improvements" }
        }
      }
    },
    {
      "id": "compact_candidates_preferences",
      "type": "call",
      "name": "Compact candidates_preferences",
      "timeout": "5m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/hourly",
          "method": "POST",
