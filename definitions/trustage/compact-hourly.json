{
  "version": "1.0",
  "name": "stawi-jobs.compact.hourly",
  "description": "Every hour at :05 — fans out one compaction call per collection to the writer's hourly compact endpoint. Merges small Parquet files written since the last compaction into larger segments, deduplicating on event_id.",
  "schedule": {
    "cron": "5 * * * *",
    "active": true
  },
  "input": {},
  "config": {},
  "timeout": "15m",
  "on_error": {
    "action": "abort"
  },
  "steps": [
    {
      "id": "compact_variants",
      "type": "call",
      "name": "Compact variants",
      "timeout": "5m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/hourly",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "variants" }
        }
      }
    },
    {
      "id": "compact_canonicals",
      "type": "call",
      "name": "Compact canonicals",
      "timeout": "5m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/hourly",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "canonicals" }
        }
      }
    },
    {
      "id": "compact_canonicals_expired",
      "type": "call",
      "name": "Compact canonicals_expired",
      "timeout": "5m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/hourly",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "canonicals_expired" }
        }
      }
    },
    {
      "id": "compact_embeddings",
      "type": "call",
      "name": "Compact embeddings",
      "timeout": "5m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/hourly",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "embeddings" }
        }
      }
    },
    {
      "id": "compact_translations",
      "type": "call",
      "name": "Compact translations",
      "timeout": "5m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/hourly",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "translations" }
        }
      }
    },
    {
      "id": "compact_published",
      "type": "call",
      "name": "Compact published",
      "timeout": "5m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/hourly",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "published" }
        }
      }
    },
    {
      "id": "compact_crawl_page_completed",
      "type": "call",
      "name": "Compact crawl_page_completed",
      "timeout": "5m",
      "on_error": { "action": "abort" },
      "call": {
