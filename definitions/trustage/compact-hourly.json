          "body": { "collection": "candidates_preferences" }
        }
      }
    },
    {
      "id": "compact_candidates_embeddings",
      "type": "call",
      "name": "Compact candidates_embeddings",
      "timeout": "5m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/hourly",
          "method": "POST",
