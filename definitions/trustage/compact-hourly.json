          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "crawl_page_completed" }
        }
      }
    },
    {
      "id": "compact_candidates_cv",
      "type": "call",
      "name": "Compact candidates_cv",
      "timeout": "5m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/hourly",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "candidates_cv" }
        }
      }
    },
    {
      "id": "compact_candidates_improvements",
      "type": "call",
      "name": "Compact candidates_improvements",
      "timeout": "5m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/hourly",
          "method": "POST",
