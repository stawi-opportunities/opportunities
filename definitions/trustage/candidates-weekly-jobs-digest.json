{
  "version": "1.0",
  "name": "opportunities.candidates.weekly-jobs-digest",
  "description": "Configurable re-engagement job summary for unpaid candidates. Fires on the cron below; matching filters by email_digest + DIGEST_WEEKLY_WEEKDAY/DIGEST_TIMEZONE. Emits candidates.weekly_jobs_digest.v1 for the notification service. Change cron_expr/timezone to retarget the wall-clock schedule.",
  "input": {},
  "config": {},
  "timeout": "15m",
  "on_error": {
    "action": "abort"
  },
  "steps": [
    {
      "id": "jobs_digest",
      "type": "call",
      "name": "Invoke unpaid jobs digest (auto cadence)",
      "timeout": "12m",
      "retry": {
        "max_attempts": 2,
        "backoff_strategy": "exponential",
        "initial_backoff": "60s"
      },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://opportunities-matching.product-opportunities.svc/_admin/candidates/weekly_jobs_digest",
          "method": "POST",
          "headers": {
            "Content-Type": "application/json",
            "X-Admin-Token": "${ADMIN_SHARED_SECRET}"
          },
          "body": {
            "cadence": "auto"
          }
        },
        "output_var": "digest_result"
      }
    }
  ],
  "schedules": [
    {
      "name": "opportunities.candidates.jobs.digest.daily",
      "cron_expr": "0 8 * * *",
      "timezone": "UTC"
    }
  ]
}
