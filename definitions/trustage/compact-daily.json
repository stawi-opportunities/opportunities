{
  "version": "1.0",
  "name": "stawi-jobs.compact.daily",
  "description": "Daily at 02:00 UTC — rebuilds the _current/ snapshot for each collection from the hourly-compacted segments. Produces a single authoritative Parquet file per collection reflecting today's full state.",
  "schedule": {
    "cron": "0 2 * * *",
    "active": true
  },
  "input": {},
  "config": {},
  "timeout": "2h",
  "on_error": {
    "action": "abort"
  },
  "steps": [
    {
      "id": "compact_daily_canonicals",
      "type": "call",
      "name": "Daily compact canonicals",
      "timeout": "30m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/daily",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "canonicals" }
        }
      }
    },
    {
      "id": "compact_daily_embeddings",
      "type": "call",
      "name": "Daily compact embeddings",
      "timeout": "30m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/daily",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "embeddings" }
        }
      }
    },
    {
      "id": "compact_daily_translations",
      "type": "call",
      "name": "Daily compact translations",
      "timeout": "30m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/daily",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "translations" }
        }
      }
    },
    {
      "id": "compact_daily_candidates_cv",
      "type": "call",
      "name": "Daily compact candidates_cv",
      "timeout": "30m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/daily",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "candidates_cv" }
        }
      }
    },
    {
      "id": "compact_daily_candidates_embeddings",
      "type": "call",
      "name": "Daily compact candidates_embeddings",
      "timeout": "30m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/daily",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "candidates_embeddings" }
        }
      }
    },
    {
      "id": "compact_daily_candidates_preferences",
      "type": "call",
      "name": "Daily compact candidates_preferences",
      "timeout": "30m",
      "on_error": { "action": "abort" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/compact/daily",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": { "collection": "candidates_preferences" }
        }
      }
    }
  ]
}
