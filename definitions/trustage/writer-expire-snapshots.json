{
  "version": "1.0",
  "name": "stawi-jobs.writer.expire-snapshots",
  "description": "Daily at 03:30 UTC: expire Iceberg snapshots older than 14 days across all append-only tables. Keeps a floor of 100 snapshots per table so recent recovery is always possible.",
  "schedule": { "cron": "30 3 * * *", "active": true },
  "input": {},
  "config": {},
  "timeout": "30m",
  "on_error": { "action": "abort" },
  "steps": [
    {
      "id": "expire",
      "type": "call",
      "name": "Invoke expire-snapshots",
      "timeout": "20m",
      "retry": { "max_attempts": 2, "backoff_strategy": "exponential", "initial_backoff": "60s" },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://stawi-jobs-writer.stawi-jobs.svc/_admin/expire-snapshots",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "body": {}
        },
        "output_var": "result"
      }
    }
  ]
}
