{
  "version": "1.0",
  "name": "opportunities.retention.expire",
  "description": "Every 15 minutes: stale-job retention sweep. Hides opportunities that vanished from their source's feed (not re-seen for max(3x crawl interval, 7 days) even though the source HAS crawled since) and restores any that reappeared. Idempotent conditional UPDATEs \u2014 always safe to fire.",
  "input": {},
  "timeout": "2m",
  "steps": [
    {
      "id": "expire",
      "type": "call",
      "name": "Run expire sweep",
      "retry": {
        "max_attempts": 3,
        "backoff_strategy": "exponential",
        "initial_backoff": "30s"
      },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://opportunities-crawler.product-opportunities.svc/admin/retention/expire",
          "method": "POST",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {}
        }
      }
    }
  ],
  "schedules": [
    {
      "name": "opportunities.retention.expire.default",
      "cron_expr": "*/15 * * * *",
      "timezone": "UTC"
    }
  ]
}
