{
  "version": "1.0",
  "name": "opportunities.candidates.matches.weekly-digest",
  "description": "Every Monday 09:00 UTC: run gap-fill matching for entitled subscribers (subscription=paid|past_due|trial), refresh candidate_matches above MATCHING_MIN_SCORE (default 0.45), and emit candidates.matches.ready.v1 for the notification service weekly email summary. Free/cancelled candidates use weekly-jobs-digest instead.",
  "input": {},
  "config": {},
  "timeout": "30m",
  "on_error": {
    "action": "abort"
  },
  "steps": [
    {
      "id": "weekly_digest",
      "type": "call",
      "name": "Invoke matches weekly digest",
      "timeout": "25m",
      "retry": {
        "max_attempts": 2,
        "backoff_strategy": "exponential",
        "initial_backoff": "60s"
      },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://opportunities-matching.product-opportunities.svc/_admin/matches/weekly_digest",
          "method": "POST",
          "headers": {
            "Content-Type": "application/json",
            "X-Admin-Token": "${ADMIN_SHARED_SECRET}"
          },
          "body": {}
        },
        "output_var": "digest_result"
      }
    }
  ],
  "schedules": [
    {
      "name": "opportunities.candidates.matches.weekly-digest.default",
      "cron_expr": "0 9 * * 1",
      "timezone": "UTC"
    }
  ]
}
