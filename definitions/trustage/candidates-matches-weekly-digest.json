{
  "version": "1.0",
  "name": "opportunities.candidates.matches.weekly-digest",
  "description": "Configurable match summary for entitled subscribers (paid|past_due|trial). Fires on the cron below; matching filters recipients by email_digest (daily|weekly|off), DIGEST_WEEKLY_WEEKDAY, and DIGEST_TIMEZONE. Gap-fills above MATCHING_MIN_SCORE and emits candidates.matches.ready.v1 for the notification service. Free users use weekly-jobs-digest.",
  "input": {},
  "config": {},
  "timeout": "30m",
  "on_error": {
    "action": "abort"
  },
  "steps": [
    {
      "id": "matches_digest",
      "type": "call",
      "name": "Invoke matches digest (auto cadence)",
      "timeout": "25m",
      "retry": {
        "max_attempts": 2,
        "backoff_strategy": "exponential",
        "initial_backoff": "60s"
      },
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://opportunities-matching.product-opportunities.svc/_admin/matches/weekly_digest",
          "method": "POST",
          "headers": {
            "Content-Type": "application/json",
            "X-Admin-Token": "${ADMIN_SHARED_SECRET}"
          },
          "body": {
            "cadence": "auto"
          }
        },
        "output_var": "digest_result"
      }
    }
  ],
  "schedules": [
    {
      "name": "opportunities.candidates.matches.digest.daily",
      "cron_expr": "0 9 * * *",
      "timezone": "UTC"
    }
  ]
}
