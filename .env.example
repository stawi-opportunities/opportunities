LOG_LEVEL=info
HTTP_PORT=:8080
OPPORTUNITY_KINDS_DIR=/tmp/opportunity-kinds
# Frame's datastore reads DATABASE_URL (not POSTGRES_DSN). Multiple
# replicas can be passed comma-separated.
DATABASE_URL=postgres://stawi:stawi@127.0.0.1:5432/stawijobs?sslmode=disable
REDIS_ADDR=127.0.0.1:6379
OPENSEARCH_URL=http://127.0.0.1:9200
QUEUE_NAME=crawl_requests
WORKER_CONCURRENCY=20
SCHEDULE_BATCH_SIZE=500
DEFAULT_COUNTRY=US
HTTP_TIMEOUT=20s
USER_AGENT=opportunities-bot/1.0 (+https://opportunities.stawi.org)
SERPAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
USAJOBS_KEY=
USAJOBS_EMAIL=
SMARTRECRUITERS_TOKEN=

# Cloudflare R2 — single account token authorised on all three product
# buckets (cluster-chronicle, product-opportunities-content,
# product-opportunities-archive). Buckets themselves are public config
# and live in the R2_*_BUCKET vars below.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_DEPLOY_HOOK_URL=

# Bucket names — public config, not secret material.
R2_CONTENT_BUCKET=product-opportunities-content
R2_ARCHIVE_BUCKET=product-opportunities-archive
R2_CHRONICLE_BUCKET=cluster-chronicle

# Public CDN origin for the content bucket. Bind this hostname to the
# product-opportunities-content R2 bucket via Cloudflare's R2 Custom
# Domain UI before traffic flows.
CONTENT_ORIGIN=https://opportunities-data.stawi.org

# --- Auto-apply ----------------------------------------------------------
# When running `make infra-up` the local NATS container exposes the bus
# on 4222; point the auto-apply queue at it so the matching service can
# publish intents into a process the consumer is reading from.
AUTO_APPLY_QUEUE_URL=nats://127.0.0.1:4222/svc.opportunities.autoapply.submit.v1

# Toggle the consumer-side kill switch / dry-run / backstops as needed.
# AUTO_APPLY_ENABLED=true
# AUTO_APPLY_DRY_RUN=false
# AUTO_APPLY_DAILY_LIMIT_BACKSTOP=10
# AUTO_APPLY_SCORE_MIN_BACKSTOP=0.0

# Browser pool — 2 headless Chromiums per pod by default.
# BROWSER_CONCURRENCY=2
# BROWSER_TIMEOUT_SEC=30
# BROWSER_USER_AGENT=

# CV download bounds. The fetcher is https-only and rejects
# RFC1918 / loopback / link-local hosts unless the binary is built with
# -tags=devmode AND AUTO_APPLY_DEV_ALLOW_INSECURE_CV=true.
# CV_MAX_BYTES=10485760
# CV_DOWNLOAD_TIMEOUT_SEC=15

# Dev-only toggles. A non-devmode build hard-fails at boot if either is
# set, so they're safe to leave defined in this example.
# AUTO_APPLY_DEV_ALLOW_INSECURE_CV=false
# AUTO_APPLY_DEV_INTENT_ENDPOINT=false

# LLM tier (Tier-2 generic form fill). Leave empty to disable; if base
# URL is set, model must be set too (boot fails otherwise).
# INFERENCE_BASE_URL=
# INFERENCE_API_KEY=
# INFERENCE_MODEL=

# SMTP fallback. Empty SMTP_HOST → email submitter degrades to skip.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_FROM=
# SMTP_PASSWORD=
