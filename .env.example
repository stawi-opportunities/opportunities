LOG_LEVEL=info
HTTP_ADDR=:8080
OPPORTUNITY_KINDS_DIR=/tmp/opportunity-kinds
POSTGRES_DSN=postgres://stawi:stawi@127.0.0.1:5432/stawijobs?sslmode=disable
REDIS_ADDR=127.0.0.1:6379
OPENSEARCH_URL=http://127.0.0.1:9200
QUEUE_NAME=crawl_requests
WORKER_CONCURRENCY=20
SCHEDULE_BATCH_SIZE=500
DEFAULT_COUNTRY=US
HTTP_TIMEOUT=20s
USER_AGENT=opportunities-bot/1.0 (+https://opportunities.stawi.org)
SERPAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
USAJOBS_KEY=
USAJOBS_EMAIL=
SMARTRECRUITERS_TOKEN=

# Cloudflare R2 — single account token authorised on all three product
# buckets (cluster-chronicle, product-opportunities-content,
# product-opportunities-archive). Buckets themselves are public config
# and live in the R2_*_BUCKET vars below.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_DEPLOY_HOOK_URL=

# Bucket names — public config, not secret material.
R2_CONTENT_BUCKET=product-opportunities-content
R2_ARCHIVE_BUCKET=product-opportunities-archive
R2_CHRONICLE_BUCKET=cluster-chronicle

# Public CDN origin for the content bucket. Bind this hostname to the
# product-opportunities-content R2 bucket via Cloudflare's R2 Custom
# Domain UI before traffic flows.
CONTENT_ORIGIN=https://opportunities-data.stawi.org
