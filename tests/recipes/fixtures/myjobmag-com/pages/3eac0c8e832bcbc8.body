{
  "@context": "http://schema.org",
    "@type": "JobPosting",
	"title": "MEAL Coordinator",
	"datePosted": "2026-06-11T13:07:58+01:00",
	"validThrough": "2026-06-21T00:00:00+0000",
	"hiringOrganization" : {

		"@type" : "Organization",
		"name" : "Jesuit Refugee Service JRS", 
