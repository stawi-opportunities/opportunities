                <h2  class="mag-b " id="job1250968">

            <span class='subjob-title'>Vehicle Renting Service for Nigeria Mission</span>
            </h2>  

        <ul class="job-key-info">

<li><span class="jkey-title">Job Type</span> <span class="jkey-info"></span></li>

<li><span class="jkey-title">Qualification</span> <span class="jkey-info"></span></li>

<li><span class="jkey-title">Experience</span> <span class="jkey-info"></span></li>

<li><span class="jkey-title">Location</span> <span class="jkey-info">Nigeria</span></li>


<li><span class="jkey-title">Job Field</span> <span class="jkey-info"><a href="/jobs-by-field/consultancy">Consultancy</a>&nbsp , <a href="/jobs-by-field/procurement-store-keeping">Procurement / Store-keeping / Supply Chain</a>&nbsp , <a href="/jobs-by-field/rfp-rfq-eoi">RFP / RFQ / EOI</a>&nbsp</span>

</li>


