                                        class="cursor-pointer text-sm not-italic text-gray-700"
                                        x-bind:class="{'font-medium text-gray-900': isSelected(item)}"
                                        x-text="item.name">
                                    </span>
                                                            </li>
                        </template>
                    </li>
                </template>

            </ul>
        </div>

