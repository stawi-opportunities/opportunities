    x-data="{
        // Desktop scroll functionality
        showRight: false,
        checkScroll() {
            const el = this.$refs.scrollContainer;
            if (el) {
                this.showRight = el.scrollLeft + el.clientWidth < el.scrollWidth - 30;
            }
        },
        // Mobile carousel functionality
        index: 0,
        count: 1,
        touchStartX: 0,
        touchEndX: 0,
        isSwiping: false,
        prev() {
            if (this.index > 0) {
                this.index--;
            } else {
                this.index = this.count - 1;
            }
        },
        next() {
            if (this.index < this.count - 1) {
                this.index++;
            } else {
                this.index = 0;
            }
        }
    }"
    x-init="checkScroll()"
    @resize.window="checkScroll()"
    class="w-full"
>
