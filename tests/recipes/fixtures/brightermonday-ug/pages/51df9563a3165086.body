        <select class="w-full h-10 pl-3 text-sm not-italic font-normal leading-5 text-gray-500 rounded-md border border-gray-300 hover:border-gray-400 focus:border-gray-400" required="true" name="abuse_type_id" x-ref="reportAbuseType" x-model="exceptAbuseType" data-parsley-error-message="Abuse Type is required" placeholder="Select..." x-on:change="() => {
