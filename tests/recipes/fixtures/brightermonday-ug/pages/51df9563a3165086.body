<script defer type="module" src="https://www.brightermonday.co.ug/build/brightermonday/assets/app-ce-o3Xb1.js"></script>

                            <script>
        function jobApply() {
            return {
                scoreAnalysis: [],
                showConditionCvModal: false,
                showConditionApplyModal: false,
                showConditionSubmitForm: false,
                showModalConditionSubmitForm: false,
                showModalConditionApplyModal: false,
                showModalApplyModal: false,
                modalReady: {
                    reportJobModal: false,
                    shareJobSMSModal: false,
                    assessmentModal: false,
                    continueAssessmentModal: false,
                    profileResumeModal: false,
                    digitalCvModal: false,
                    clickApplyModal: false,
                    lowScoreModal: false,
                    profileCompletionModal: false,
                    'preview-cv-modal': false,
                },
                markModalReady(modalName) {
                    if (Object.prototype.hasOwnProperty.call(this.modalReady, modalName)) {
                        this.modalReady[modalName] = true;
                    }
                },
                init() {
                    const scoreAnalysisEl = document.querySelector(".score-analysis");
                    if (scoreAnalysisEl) {
                        try {
                            this.scoreAnalysis = JSON.parse(scoreAnalysisEl.dataset.scoreAnalysis);
                        } catch (e) {
                            this.scoreAnalysis = [];
                        }
                    }

                    setTimeout(() => this.updateButtons(), 100);

                    this.$watch('$store.global.modal', (modalName) => {
                        if (!modalName) return;

                        if (!this.modalReady[modalName]) {
                            // Registers the component to DOM
                            this.markModalReady(modalName);

                            this.$nextTick(() => {
                                // Re-triggers the modal
                                this.$store.global.modal = modalName;
                            });
                        }
                    });
                },
                updateButtons(currentCV = null) {
                    if (currentCV === null) {
                        const currentCVInput = document.getElementById("current_cv");
                        const value = currentCVInput?.value;
                        switch (value) {
                            case '0':
                                currentCV = "new_cv";
                                break;
                            case '1':
                                currentCV = "existing_cv";
                                break;
                            case '2':
                                currentCV = "profile_cv";
                                break;
                            default:
                                currentCV = null;
                        }
                    }

                    const currentCvProfileChecked = currentCV === "profile_cv";
                    const useAttachedCv = currentCV === "existing_cv"
                        || currentCV === "new_cv";
                    const outdatedProfile = this.scoreAnalysis.includes("outdated_profile");
                    const lowScore = this.scoreAnalysis.includes("low_matching_score");
                    const failedProfileCheck = outdatedProfile || lowScore;
                    const passedProfileCheck = !failedProfileCheck;
                    if (useAttachedCv) {
                        this.showConditionCvModal = false;
                        this.showConditionApplyModal = false;
                        this.showConditionSubmitForm = true;
                        this.showModalConditionSubmitForm = false;
                        this.showModalConditionApplyModal = false;
                        this.showModalApplyModal = false;
                    } else if (passedProfileCheck && currentCvProfileChecked) {
                        this.showConditionCvModal = true;
                        this.showConditionApplyModal = false;
                        this.showConditionSubmitForm = false;
                        this.showModalConditionSubmitForm = false;
                        this.showModalConditionApplyModal = false;
                        this.showModalApplyModal = true;
                    } else if (failedProfileCheck && currentCvProfileChecked) {
                        this.showConditionCvModal = false;
                        this.showConditionApplyModal = true;
                        this.showConditionSubmitForm = false;
                        this.showModalConditionSubmitForm = false;
                        this.showModalConditionApplyModal = true;
                        this.showModalApplyModal = false;
                    }
                }
            }
        }
    </script>
