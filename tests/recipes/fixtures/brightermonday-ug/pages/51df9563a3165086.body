                x-on:scroll.passive="loadMoreOptions()"
                x-on:mouseenter.once="$nextTick(() => {
                    
                    const container = $refs['mobile_number_countryPanel'];
                    if (container && container.scrollHeight > container.clientHeight && container.scrollHeight > 0) {
