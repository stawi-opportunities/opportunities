{
  "@context": "http://schema.org",
    "@type": "JobPosting",
	"title": "Manager - Marketing, Digital, Brand & Customer Experience",
	"datePosted": "2026-06-11T15:21:25+01:00",
	"validThrough": "2026-06-25T00:00:00+0000",
	"hiringOrganization" : {

