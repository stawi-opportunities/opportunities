{
  "@context": "http://schema.org",
    "@type": "JobPosting",
	"title": "Senior Accountant (Ex-Audit | Big 4 Level) – Dutch Clients",
	"datePosted": "2026-06-10T13:57:59+01:00",
	"validThrough": "2026-06-24T00:00:00+0000",
	"hiringOrganization" : {

		"@type" : "Organization",
		"name" : "FairChain WorkForce", 
