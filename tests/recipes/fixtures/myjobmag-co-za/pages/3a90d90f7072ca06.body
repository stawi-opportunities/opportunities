				<li><a href="javascript:;" onclick="document.location.hash='job1251121';">Senior Catering Manager</a></li>

            
				<li><a href="javascript:;" onclick="document.location.hash='job1251122';">Junior Catering Manager</a></li>

            
             </ol>

